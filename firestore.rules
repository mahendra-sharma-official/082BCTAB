rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user's email has been verified
    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }
    
    // Helper function to check if the user's email matches the allowed pcampus domain format
    function isPcampusEmail(email) {
      return email.matches("(?i)^[0-9]{3}bct(00[1-9]|0[1-3][0-9]|04[0-8])\\.[a-z0-9._%+-]+@pcampus\\.edu\\.np$");
    }
    
    // Helper function to check if email is in the Exception Emails list
    function isExceptionEmail(email) {
      return exists(/databases/$(database)/documents/exceptionEmails/$(email));
    }
    
    // Helper function to check if email is valid (matches pattern or exception)
    function isValidEmail() {
      return isPcampusEmail(request.auth.token.email) || isExceptionEmail(request.auth.token.email);
    }
    
    // Helper function to check if user has a specific role safely
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == roleName;
    }
    
    // Check if user is Admin (Hardcoded fallback ensures this works even if roles doc is missing/deleted)
    function isAdmin() {
      return request.auth.token.email == "082bct013.apil@pcampus.edu.np" || hasRole('admin');
    }
    
    // Check if user is Admin or Moderator
    function isAdminOrModerator() {
      return isAdmin() || hasRole('moderator');
    }
    
    // Check if user can manage events (Admin, Moderator, CR, or Locus CR)
    function canManageEvents() {
      return isAdmin() || hasRole('moderator') || hasRole('cr') || hasRole('locus_cr');
    }

    // Deny-by-default root fallback
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users collection
    match /users/{uid} {
      allow read: if isVerified();
      allow create: if isVerified() && request.auth.uid == uid && isValidEmail();
      allow update: if isVerified() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // 2. Roles collection
    match /roles/{uid} {
      allow read: if isVerified();
      allow create: if isVerified() && (
        (uid == request.auth.uid && (
          (request.auth.token.email == "082bct013.apil@pcampus.edu.np" && request.resource.data.role == "admin") ||
          (request.auth.token.email != "082bct013.apil@pcampus.edu.np" && request.resource.data.role == "student" && isValidEmail())
        )) ||
        isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // 3. Exception Emails collection
    match /exceptionEmails/{email} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    // 4. Projects collection
    match /projects/{projectId} {
      allow read: if isVerified();
      allow create: if isVerified() && request.resource.data.ownerUid == request.auth.uid && isValidEmail();
      allow update: if isVerified() && (
        resource.data.ownerUid == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stars', 'starredBy']))
      );
      allow delete: if isVerified() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // 5. Events collection
    match /events/{eventId} {
      allow read: if isVerified();
      allow create, update, delete: if canManageEvents();
    }

    // 6. Messages (1:1 chat)
    match /messages/{chatId} {
      allow read, write: if isVerified() && chatId.split("_").hasAny([request.auth.uid]);
      
      match /thread/{msgId} {
        allow read: if isVerified() && chatId.split("_").hasAny([request.auth.uid]);
        allow create: if isVerified() && 
                      chatId.split("_").hasAny([request.auth.uid]) && 
                      request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // 7. Showcases collection
    match /showcases/{uid} {
      allow read: if isVerified();
      allow create, update: if isVerified() && request.auth.uid == uid && isValidEmail();
      allow delete: if isVerified() && (request.auth.uid == uid || isAdmin());
    }

    // 8. Banned emails collection
    match /bannedEmails/{email} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }
  }
}